---
import type { GetStaticPaths } from 'astro';
import Pagination from '../../components/Pagination.astro';
import PostCard from '../../components/PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../../utils/posts';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getPublishedPosts();
  return paginate(posts, { pageSize: 12 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const isFirstPage = page.currentPage === 1;
const title = isFirstPage ? 'Blog' : `Blog — Página ${page.currentPage}`;
const description =
  'Todos os artigos do Hotmoney sobre renda extra: serviços, internet, IA e investimentos para ganhar mais no Brasil.';
const canonical = new URL(page.url.current, Astro.site).href;
const prevUrl = page.url.prev ? new URL(page.url.prev, Astro.site).href : undefined;
const nextUrl = page.url.next ? new URL(page.url.next, Astro.site).href : undefined;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  {
    prevUrl && <link rel="prev" href={prevUrl} slot="head" />
  }
  {
    nextUrl && <link rel="next" href={nextUrl} slot="head" />
  }

  <section class="blog container" aria-labelledby="blog-heading">
    <header class="blog__header">
      <h1 id="blog-heading" class="blog__title">{isFirstPage ? 'Blog' : `Blog — Página ${page.currentPage}`}</h1>
      <p class="blog__description">{description}</p>
    </header>

    <div class="post-grid">
      {
        page.data.map((post, index) => (
          <PostCard post={post} eager={isFirstPage && index === 0} headingLevel="h2" />
        ))
      }
    </div>

    {page.lastPage > 1 && <Pagination page={page} />}
  </section>
</BaseLayout>

<style>
  .blog {
    padding-block: var(--space-7) var(--space-8);
  }

  .blog__header {
    max-width: 40rem;
    margin-inline: auto;
    margin-bottom: var(--space-7);
    text-align: center;
  }

  .blog__title {
    font-size: var(--text-3xl);
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .blog__description {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    line-height: 1.6;
  }
</style>
