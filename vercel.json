{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/como-monetizar-um-hobby",
      "destination": "/como-monetizar-um-hobby-guia-completo",
      "permanent": true
    },
    {
      "source": "/aplicativos-de-renda-extra",
      "destination": "/renda-extra-com-aplicativos-guia-completo",
      "permanent": true
    },
    {
      "source": "/blog/:slug((?![0-9]+$)(?!$).*)",
      "destination": "/:slug",
      "permanent": true
    },
    {
      "source": "/posts/:slug*",
      "destination": "/:slug*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
