---
const year = new Date().getFullYear();

const footerNav = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
];

const institutionalNav = [
  { href: '/sobre', label: 'Sobre' },
  { href: '/contato', label: 'Contato' },
  { href: '/politica-de-privacidade', label: 'Privacidade' },
  { href: '/politica-de-cookies', label: 'Cookies' },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <p class="footer__brand">
      <a href="/" class="footer__logo" aria-label="Hotmoney — página inicial">Hotmoney</a>
    </p>

    <nav aria-label="Rodapé">
      <ul class="footer__nav">
        {
          footerNav.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <nav aria-label="Links institucionais">
      <ul class="footer__nav footer__nav--institutional">
        {
          institutionalNav.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <p class="footer__copy">
      &copy; {year} Hotmoney. Todos os direitos reservados.
      <a href="/rss.xml" class="footer__rss">RSS</a>
    </p>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--space-8);
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .footer__inner {
    display: grid;
    gap: var(--space-5);
    padding-block: var(--space-7);
    text-align: center;
  }

  .footer__logo {
    font-size: var(--text-lg);
    font-weight: 800;
    text-decoration: none;
    color: var(--color-brand-text);
  }

  .footer__nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4) var(--space-6);
  }

  .footer__nav--institutional {
    font-size: var(--text-sm);
  }

  .footer__nav a {
    font-weight: 600;
    text-decoration: none;
    color: var(--color-text-muted);
  }

  .footer__nav a:hover {
    color: var(--color-brand-text);
  }

  .footer__copy {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .footer__rss {
    margin-left: var(--space-3);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .footer__rss:hover {
    color: var(--color-brand-text);
  }

  @media (min-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr auto;
      align-items: start;
      text-align: left;
    }

    .footer__brand {
      grid-column: 1;
      grid-row: 1;
    }

    .footer__inner > nav:first-of-type {
      grid-column: 2;
      grid-row: 1;
    }

    .footer__inner > nav:last-of-type {
      grid-column: 1 / -1;
      grid-row: 2;
    }

    .footer__nav--institutional {
      justify-content: flex-start;
    }

    .footer__copy {
      grid-column: 1 / -1;
      grid-row: 3;
      text-align: center;
    }
  }
</style>
