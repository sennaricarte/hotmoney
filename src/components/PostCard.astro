---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getCategoryHref, getCategoryName } from '../data/categories';
import { formatDate } from '../utils/date';

interface Props {
  post: CollectionEntry<'posts'>;
  eager?: boolean;
  featured?: boolean;
  headingLevel?: 'h2' | 'h3';
}

const { post, eager = false, featured = false, headingLevel = 'h2' } = Astro.props;
const imageWidths = featured ? [600, 900, 1200] : [400, 600, 800, 1200];
const { title, description, pubDate, cover, coverAlt, category } = post.data;
const Heading = headingLevel;
const postUrl = `/${post.id}`;
const isSvg = cover.format === 'svg';
---

<article class:list={['card', featured && 'card--featured']}>
  <div class="card__media">
    {
      isSvg ? (
        <img
          src={cover.src}
          alt=""
          width={1200}
          height={630}
          loading={eager ? 'eager' : 'lazy'}
          fetchpriority={eager ? 'high' : undefined}
          decoding={eager ? undefined : 'async'}
        />
      ) : (
        <Image
          src={cover}
          alt=""
          width={1200}
          height={630}
          widths={imageWidths}
          formats={['avif', 'webp']}
          loading={eager ? 'eager' : 'lazy'}
          fetchpriority={eager ? 'high' : undefined}
          decoding={eager ? undefined : 'async'}
        />
      )
    }
  </div>
  <div class="card__body">
    <a href={getCategoryHref(category)} class="badge">{getCategoryName(category)}</a>
    <Heading class="card__title">
      <a href={postUrl}>{title}</a>
    </Heading>
    <p class="card__description">{description}</p>
    <time class="card__date" datetime={pubDate.toISOString()}>
      {formatDate(pubDate)}
    </time>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  @media (prefers-reduced-motion: no-preference) {
    .card {
      transition:
        transform 0.2s ease,
        box-shadow 0.2s ease;
    }

    .card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-md);
    }
  }

  .card--featured {
    grid-column: 1 / -1;
  }

  .card__media {
    display: block;
    aspect-ratio: 1200 / 630;
    overflow: hidden;
  }

  .card__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
  }

  .card--featured .card__title {
    font-size: var(--text-2xl);
  }

  .card__title {
    font-size: var(--text-xl);
    line-height: 1.2;
  }

  .card__title a {
    text-decoration: none;
    color: var(--color-text);
  }

  .card__title a:hover {
    color: var(--color-brand-text);
  }

  .card__description {
    flex: 1;
    color: var(--color-text-muted);
    font-size: var(--text-base);
  }

  .card__date {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  @media (min-width: 768px) {
    .card--featured {
      flex-direction: row;
      align-items: stretch;
      min-height: 18rem;
    }

    .card--featured .card__media {
      flex: 1.15;
      aspect-ratio: auto;
      min-height: 100%;
    }

    .card--featured .card__body {
      flex: 1;
      justify-content: center;
      padding: var(--space-6) var(--space-7);
      gap: var(--space-4);
    }

    .card--featured .card__description {
      font-size: var(--text-lg);
    }
  }
</style>
