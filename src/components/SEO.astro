---
import type { ImageMetadata } from 'astro';
import { getImage } from 'astro:assets';
import ogDefault from '../assets/og-default.png';
import type { BreadcrumbItem } from '../utils/json-ld';
import { getBlogPostingSchema, getBreadcrumbSchema } from '../utils/json-ld';
import { stripMarkdown } from '../utils/strip-markdown';

interface Props {
  title: string;
  description: string;
  canonical: string;
  type?: 'website' | 'article';
  ogImage?: ImageMetadata | string;
  article?: {
    pubDate: Date;
    updatedDate?: Date;
  };
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title,
  description,
  canonical,
  type = 'website',
  ogImage,
  article,
  breadcrumbs,
} = Astro.props;

const siteName = 'Hotmoney';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const cleanDescription = stripMarkdown(description);

const defaultOg = await getImage({
  src: ogDefault,
  width: 1200,
  height: 630,
  format: 'jpg',
  quality: 85,
});

let ogImageUrl = new URL(defaultOg.src, Astro.site).href;

if (typeof ogImage === 'string') {
  ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).href;
} else if (ogImage) {
  if (ogImage.format === 'svg') {
    ogImageUrl = new URL(ogImage.src, Astro.site).href;
  } else {
    const optimized = await getImage({ src: ogImage, width: 1200, height: 630, format: 'jpg', quality: 85 });
    ogImageUrl = new URL(optimized.src, Astro.site).href;
  }
}

const articleJsonLd =
  type === 'article' && article
    ? getBlogPostingSchema({
        site: Astro.site!,
        title,
        description: cleanDescription,
        canonical,
        imageUrl: ogImageUrl,
        pubDate: article.pubDate,
        updatedDate: article.updatedDate,
      })
    : null;

const breadcrumbJsonLd = breadcrumbs?.length ? getBreadcrumbSchema(breadcrumbs) : null;
---

<title>{fullTitle}</title>
<meta name="description" content={cleanDescription} />
<link rel="canonical" href={canonical} />

<meta property="og:type" content={type} />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={cleanDescription} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:locale" content="pt_BR" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={cleanDescription} />
<meta name="twitter:image" content={ogImageUrl} />

{articleJsonLd && <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />}
{breadcrumbJsonLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />}
