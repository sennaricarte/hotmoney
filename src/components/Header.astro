---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/sobre', label: 'Sobre' },
  { href: '/contato', label: 'Contato' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string): boolean {
  const normalized = href.replace(/\/$/, '') || '/';
  return currentPath === normalized;
}
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="logo" aria-label="Hotmoney — página inicial">
      Hot<span>money</span>
    </a>

    <nav class="nav nav--desktop" aria-label="Principal">
      <ul class="nav__list">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <button
      type="button"
      class="menu-toggle"
      popovertarget="mobile-nav"
      popovertargetaction="toggle"
      aria-controls="mobile-nav"
      aria-expanded="false"
      aria-label="Abrir menu de navegação"
    >
      <span aria-hidden="true" class="menu-toggle__icon" />
    </button>

    <nav
      id="mobile-nav"
      popover="auto"
      class="nav nav--mobile"
      aria-label="Principal mobile"
    >
      <ul class="nav__list">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-border);
    background: rgb(255 250 247 / 0.92);
    backdrop-filter: blur(8px);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: var(--space-4);
  }

  .logo {
    font-size: var(--text-xl);
    font-weight: 800;
    letter-spacing: -0.02em;
    text-decoration: none;
    color: var(--color-text);
  }

  .logo span {
    color: var(--color-brand-text);
  }

  .nav__list {
    display: flex;
    gap: var(--space-5);
  }

  .nav a {
    font-weight: 600;
    text-decoration: none;
    color: var(--color-text-muted);
    transition: color 0.15s ease;
  }

  .nav a:hover,
  .nav a[aria-current='page'] {
    color: var(--color-brand-text);
  }

  .nav--desktop {
    display: none;
  }

  .menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    cursor: pointer;
  }

  .menu-toggle__icon {
    width: 1.25rem;
    height: 2px;
    background: var(--color-text);
    box-shadow:
      0 -6px 0 var(--color-text),
      0 6px 0 var(--color-text);
  }

  .nav--mobile {
    inset: unset;
    top: 4.5rem;
    right: var(--space-4);
    left: var(--space-4);
    margin: 0;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    box-shadow: var(--shadow-md);
  }

  .nav--mobile .nav__list {
    flex-direction: column;
    gap: var(--space-3);
  }

  .nav--mobile a {
    display: block;
    padding: var(--space-2) var(--space-3);
    border-radius: calc(var(--radius) / 2);
  }

  .nav--mobile a:hover {
    background: var(--color-bg);
  }

  @media (min-width: 768px) {
    .nav--desktop {
      display: block;
    }

    .menu-toggle,
    .nav--mobile {
      display: none;
    }
  }
</style>
