---
import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  posts: CollectionEntry<'posts'>[];
}

const { post, posts } = Astro.props;
const limit = 3;

const others = posts.filter((entry) => entry.id !== post.id);

const sameCategory = others
  .filter((entry) => entry.data.category === post.data.category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const related: CollectionEntry<'posts'>[] = [];
const usedIds = new Set<string>();

for (const entry of sameCategory) {
  if (related.length >= limit) break;
  related.push(entry);
  usedIds.add(entry.id);
}

if (related.length < limit) {
  const fromOtherCategories = others
    .filter((entry) => !usedIds.has(entry.id))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  for (const entry of fromOtherCategories) {
    if (related.length >= limit) break;
    related.push(entry);
  }
}
---

{
  related.length > 0 && (
    <section class="related container" aria-labelledby="related-heading">
      <h2 id="related-heading" class="related__title">Leia também</h2>
      <div class="post-grid">
        {related.map((entry) => (
          <PostCard post={entry} headingLevel="h3" />
        ))}
      </div>
    </section>
  )
}

<style>
  .related {
    padding-block: var(--space-7) var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .related__title {
    margin-bottom: var(--space-6);
    font-size: var(--text-2xl);
    line-height: 1.2;
    letter-spacing: -0.01em;
    text-align: center;
  }
</style>
