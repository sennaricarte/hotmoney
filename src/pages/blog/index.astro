---
import { getCollection } from 'astro:content';
import PostCard from '../../components/PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const title = 'Blog';
const description =
  'Todos os artigos do Hotmoney sobre renda extra: serviços, internet, IA e investimentos para ganhar mais no Brasil.';
const canonical = new URL('/blog', Astro.site).href;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <section class="blog container" aria-labelledby="blog-heading">
    <header class="blog__header">
      <h1 id="blog-heading" class="blog__title">Blog</h1>
      <p class="blog__description">{description}</p>
    </header>

    <div class="post-grid">
      {
        posts.map((post, index) => (
          <PostCard post={post} eager={index === 0} headingLevel="h2" />
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .blog {
    padding-block: var(--space-7) var(--space-8);
  }

  .blog__header {
    max-width: 40rem;
    margin-inline: auto;
    margin-bottom: var(--space-7);
    text-align: center;
  }

  .blog__title {
    font-size: var(--text-3xl);
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .blog__description {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    line-height: 1.6;
  }
</style>
